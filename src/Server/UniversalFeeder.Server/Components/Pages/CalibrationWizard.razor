@page "/calibrate/{FeederId:int}"
@using UniversalFeeder.Server.Services
@using UniversalFeeder.Server.Models
@using UniversalFeeder.Server.Data
@using Microsoft.EntityFrameworkCore
@inject IFeederClient FeederClient
@inject IFeedTypeService FeedTypeService
@inject IFeederService FeederService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Calibration Wizard</PageTitle>

<h1>Calibration Wizard</h1>

<div class="progress mb-4" style="height: 25px;">
    <div class="progress-bar" role="progressbar" style="width: @(step * 33)%;" aria-valuenow="@(step * 33)" aria-valuemin="0" aria-valuemax="100">Step @step of 3</div>
</div>

@if (feeder == null)
{
    <p>Loading feeder data...</p>
}
else
{
    <div class="card">
        <div class="card-body">
            @if (step == 1)
            {
                <h5 class="card-title">Step 1: Select Feed Type</h5>
                <p>What kind of feed are you calibrating for feeder <strong>@feeder.Nickname</strong>?</p>
                
                <div class="mb-3">
                    <label class="form-label">Existing Types:</label>
                    <select class="form-select" @bind="selectedFeedTypeId">
                        <option value="0">-- Create New Type --</option>
                        @foreach (var type in availableTypes)
                        {
                            <option value="@type.Id">@type.Name (@type.GramsPerSecond g/s)</option>
                        }
                    </select>
                </div>

                @if (selectedFeedTypeId == 0)
                {
                    <div class="mb-3">
                        <label class="form-label">New Feed Type Name:</label>
                        <input type="text" class="form-control" @bind="newFeedTypeName" placeholder="e.g. Sheep Pellets" />
                    </div>
                }

                <button class="btn btn-primary" @onclick="NextStep">Next</button>
            }
            else if (step == 2)
            {
                <h5 class="card-title">Step 2: Test Dispense</h5>
                <p>Place a container under the feeder and press the button below. The motor will run for <strong>10 seconds</strong>.</p>
                <p>Feed Type: <strong>@(selectedFeedTypeId == 0 ? newFeedTypeName : availableTypes.First(t => t.Id == selectedFeedTypeId).Name)</strong></p>

                <button class="btn btn-warning btn-lg" @onclick="RunTestDispense" disabled="@isDispensing">
                    @(isDispensing ? "Dispensing..." : "Start 10s Test Run")
                </button>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert alert-info mt-3">@statusMessage</div>
                }

                <div class="mt-4">
                    <button class="btn btn-secondary" @onclick="PrevStep">Back</button>
                    <button class="btn btn-primary" @onclick="NextStep" disabled="@(!dispenseComplete)">Next</button>
                </div>
            }
            else if (step == 3)
            {
                <h5 class="card-title">Step 3: Calculate & Save</h5>
                <p>Weigh the dispensed feed and enter the weight below.</p>
                
                <div class="mb-3">
                    <label class="form-label">Weight in Grams:</label>
                    <input type="number" class="form-control" @bind="measuredWeight" />
                </div>

                @if (measuredWeight > 0)
                {
                    <div class="alert alert-success">
                        Calculated Speed: <strong>@(measuredWeight / 10.0) grams/second</strong>
                    </div>
                }

                <div class="mt-4">
                    <button class="btn btn-secondary" @onclick="PrevStep">Back</button>
                    <button class="btn btn-success" @onclick="FinishCalibration">Finish & Save</button>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public int FeederId { get; set; }
    private Feeder? feeder;
    private List<FeedType> availableTypes = new();
    private int step = 1;
    
    // Step 1
    private int selectedFeedTypeId;
    private string? newFeedTypeName;

    // Step 2
    private bool isDispensing;
    private bool dispenseComplete;
    private string? statusMessage;

    // Step 3
    private double measuredWeight;

    protected override async Task OnInitializedAsync()
    {
        feeder = await FeederService.GetFeederByIdAsync(FeederId);
        availableTypes = await FeedTypeService.GetFeedTypesAsync();
    }

    private void NextStep() => step++;
    private void PrevStep() => step--;

    private async Task RunTestDispense()
    {
        if (feeder == null) return;
        
        isDispensing = true;
        statusMessage = "Sending command to feeder...";
        StateHasChanged();

        bool success = await FeederClient.TriggerFeedAsync(feeder.UniqueId, 10000);
        
        isDispensing = false;
        if (success)
        {
            dispenseComplete = true;
            statusMessage = "Dispense complete. Please weigh the output.";
        }
        else
        {
            statusMessage = "Error: Could not communicate with feeder.";
        }
    }

    private async Task FinishCalibration()
    {
        if (feeder == null || measuredWeight <= 0) return;

        FeedType type;
        if (selectedFeedTypeId == 0)
        {
            type = new FeedType { Name = newFeedTypeName ?? "Unnamed Feed" };
        }
        else
        {
            type = availableTypes.First(t => t.Id == selectedFeedTypeId);
        }

        type.GramsPerSecond = measuredWeight / 10.0;
        var savedType = await FeedTypeService.SaveFeedTypeAsync(type);

        feeder.FeedTypeId = savedType.Id;
        await FeederService.SaveFeederAsync(feeder);

        Navigation.NavigateTo("/manual-feed");
    }
}
