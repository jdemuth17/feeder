<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="UniversalFeeder.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:UniversalFeeder.Mobile.Views"
    Title="Universal Feeder">

    <ShellContent
        Title="My Feeders"
        ContentTemplate="{DataTemplate views:DashboardPage}"
        Route="DashboardPage" />

    <ShellContent
        Title="Setup"
        ContentTemplate="{DataTemplate views:ProvisioningPage}"
        Route="ProvisioningPage" />

</Shell>
